# Panel admin (Next.js) — copiar a .env.local y completar con valores reales.
# Los valores reales NUNCA se commitean (ver SECURITY.md).
# Obtener desde: https://supabase.com/dashboard → tu proyecto → Settings → API

# ── Expuestas al navegador (prefijo NEXT_PUBLIC_) ──
# La anon key es segura en el cliente porque RLS protege cada fila.
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ── Solo servidor — NUNCA exponer al navegador ──
# La service_role key salta RLS. Úsala solo en código server-side (route handlers,
# server actions). Si aparece en el bundle del cliente, es una brecha de seguridad.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ── Opcional ──
# URL pública del panel admin, usada para armar el link de invitación de
# conserjes. Si no se define, se deriva de los headers del request.
# NEXT_PUBLIC_SITE_URL=https://admin.portia.cl

# ── Stripe — signup con muralla de pago ──
# Dashboard de Stripe → Developers → API keys. Usar las de test (sk_test_...)
# hasta que el flujo esté probado de punta a punta.
STRIPE_SECRET_KEY=sk_test_tu_key_aqui
# Developers → Webhooks → tu endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_tu_secret_aqui
# Product catalog → tu producto de suscripción mensual → Pricing → API ID del price.
STRIPE_PRICE_ID_MENSUAL=price_tu_id_aqui
